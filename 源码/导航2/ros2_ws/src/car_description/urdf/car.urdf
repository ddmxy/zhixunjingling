<?xml version="1.0"?>
<robot name="rdk_nav_car">
  <link name="base_footprint"/>

  <joint name="base_footprint_to_base_link" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <!-- base_link origin = chassis bottom plate center; 52.58 mm above ground -->
    <origin xyz="0 0 0.05258" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <geometry>
        <box size="0.2446 0.1847 0.12"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <geometry>
        <box size="0.2446 0.1847 0.12"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <mass value="3.0"/>
      <inertia ixx="0.02" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.03"/>
    </inertial>
  </link>

  <joint name="base_to_laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <!-- Measured from bottom plate center, on centerline: +X 96 mm, +Z 78.55 mm -->
    <!-- LASER_MOUNT_YAW replaced at launch from config/sensor_calibration.yaml -->
    <origin xyz="0.096 0 0.07855" rpy="0 0 LASER_MOUNT_YAW"/>
  </joint>
  <link name="laser">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.05"/>
      </geometry>
      <material name="blue">
        <color rgba="0.1 0.1 0.8 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="base_to_imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <!-- Measured: below plate on centerline, +X 28.33 mm, Z -6 mm from plate center -->
    <origin xyz="0.02833 0 -0.006" rpy="0 0 0"/>
  </joint>
  <link name="imu_link"/>
</robot>

